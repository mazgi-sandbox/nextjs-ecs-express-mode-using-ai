model User {
  id            String   @id @default(cuid(2))
  email         String   @unique
  name          String?
  passwordHash  String?
  totpSecret    String?
  totpEnabled   Boolean  @default(false)
  recoveryCodes Json?
  preferences   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         Item[]
}
