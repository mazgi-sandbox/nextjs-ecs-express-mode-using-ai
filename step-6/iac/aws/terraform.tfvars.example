app_unique_id = "oauth2-app"

aws_region = "us-east-1"

# Container image tag (registry URL is derived from ECR repository outputs)
# image_tag = "latest"

# Database
# NOTE: database_password is stored in Secrets Manager (as part of DATABASE_URL)
# at runtime — never exposed as a plaintext ECS environment variable.
database_password = "CHANGE_ME"

# JWT, Session, and SMTP secrets are stored directly in Secrets Manager.
# Populate them externally (CI or AWS Console) — not managed by Terraform.
