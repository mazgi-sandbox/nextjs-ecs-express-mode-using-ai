# GitHub Actions Variables & Local Configuration (non-sensitive)
# Copy to .env for local development, or to .staging.env / .production.env for CI.
# See docs/ci.md for the env file naming convention.

# -------------------------------------------------------
# Container user (Linux only)
# Prevents node_modules and .pnpm-store from being created with root ownership.
# Set these to your host user's UID/GID: run `id -u` and `id -g` to get them.
# Not needed on macOS — Docker Desktop for Mac handles file ownership automatically.
# -------------------------------------------------------
#UID=1000
#GID=1000

# -------------------------------------------------------
# Backend configuration
# -------------------------------------------------------

# Port the NestJS server listens on.
PORT=4000

# Comma-separated list of allowed CORS origins (e.g. http://localhost:3000,https://example.com).
# Defaults to http://localhost:3000 if not set.
CORS_ORIGIN=http://localhost:3000,http://web:3000

# Lifetime of an access token (e.g. 15m, 1h).
AUTH_JWT_ACCESS_EXPIRATION=15m

# Lifetime of a refresh token (e.g. 7d, 30d).
AUTH_JWT_REFRESH_EXPIRATION=7d

# -------------------------------------------------------
# SMTP (email)
# Local development uses Mailpit (SMTP on port 1025, UI on http://localhost:8025).
# For production, set these to your SMTP provider (e.g. SES, SendGrid).
# -------------------------------------------------------

# SMTP server hostname.
# For Amazon SES: email-smtp.{region}.amazonaws.com
SMTP_HOST=mailpit

# SMTP server port.
# For Amazon SES: 587 (STARTTLS) or 465 (TLS Wrapper).
SMTP_PORT=1025

# Use implicit TLS (port 465). Set to false for STARTTLS (port 587).
# Mailpit and STARTTLS use false; TLS Wrapper (port 465) uses true.
SMTP_SECURE=false

# SMTP username (for Amazon SES: IAM SMTP credential username).
# Not needed for local Mailpit.
#SMTP_USER=

# From address for outgoing emails.
# For Amazon SES: must be a verified identity (email or domain).
SMTP_FROM=noreply@localhost

# -------------------------------------------------------
# Cloud provider CLI profiles (used by the iac container)
# The iac container mounts ~/.aws as read-only.
# Set the profile/environment variables below so Terraform can locate your credentials.
# -------------------------------------------------------

# AWS SSO profile name. Run `aws configure list-profiles` to list available profiles.
# Required when using AWS SSO (`aws sso login --profile <name>`).
# Leave commented out if using long-lived IAM credentials (~/.aws/credentials).
#AWS_PROFILE=

# -------------------------------------------------------
# AWS
# -------------------------------------------------------

# IAM role ARN with GitHub OIDC trust policy (used for IaC and production image push).
AWS_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/github-actions-iac

# S3 bucket name for Terraform state storage.
AWS_TF_STATE_BUCKET=my-terraform-state

# AWS region where the S3 state bucket is located.
AWS_TF_STATE_REGION=us-east-1

# AWS region for resource deployment (may differ from AWS_TF_STATE_REGION).
AWS_REGION=us-east-1

# -------------------------------------------------------
# Terraform variables
# All TF_VAR_* mappings are derived automatically via
# compose.yaml (iac service environment) and GitHub Actions workflows.
# -------------------------------------------------------

# Unique prefix for all cloud resource names (e.g. ECR repos, resource groups, Cloud Run services).
APP_UNIQUE_ID=oauth2-app


# Container image tag (optional, defaults to latest).
# IMAGE_TAG=latest
